{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "jsx": "react-jsx",

    "module": "ESNext",
    "moduleResolution": "Node",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "strict": false,
    "skipLibCheck": true
  },

  "include": ["src"]
}
