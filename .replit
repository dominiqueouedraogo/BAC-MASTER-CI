modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "heroku config:setDATABASE_URLpostgresql://neondb_owner:npg_WPaJsNdX6iI3@ep-frosty-cake-akdklxse.c-3.us-west-2.aws.neon.tech/neondb?sslmode=require"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.production]
DATABASE_URL = "postgresql://neondb_owner:npg_WPaJsNdX6iI3@ep-frosty-cake-akdklxse.c-3.us-west-2.aws.neon.tech/neondb?sslmode=require"
